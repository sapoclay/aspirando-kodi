msgctxt "#30001"
msgid "Aspirando Kodi Settings"
msgstr "Configuración de Aspirando Kodi"

msgctxt "#30002"
msgid "Use custom ReadBufferFactor"
msgstr "Usar Factor de Lectura personalizado"

msgctxt "#30003"
msgid "ReadBufferFactor value (1.0 - 8.0)"
msgstr "Valor del Factor de Lectura (1.0 - 8.0)"

msgctxt "#30004"
msgid "Enable Android-specific optimizations"
msgstr "Habilitar optimizaciones para Android"

msgctxt "#30005"
msgid "Android buffer size limit"
msgstr "Límite de buffer para Android"

msgctxt "#30006"
msgid "Enable audio/video sync corrections"
msgstr "Habilitar correcciones de sincronización A/V"

msgctxt "#30007"
msgid "Video delay correction (ms)"
msgstr "Corrección de retraso de video (ms)"

msgctxt "#30008"
msgid "Audio delay correction (ms)"
msgstr "Corrección de retraso de audio (ms)"

msgctxt "#30009"
msgid "Use conservative buffering (reduces stuttering)"
msgstr "Usar buffering conservador (reduce cortes)"

msgctxt "#30010"
msgid "Enable aggressive prefetch (faster loading)"
msgstr "Habilitar precarga agresiva (carga más rápida)"
