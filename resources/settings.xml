<?xml version="1.0" encoding="UTF-8"?>
<settings>
    <category label="30001">
        <!-- Configuración de Factor de Lectura -->
        <setting id="custom_readbufferfactor_enabled" type="bool" label="30002" default="false"/>
        <setting id="custom_readbufferfactor" type="slider" label="30003" default="6.0" range="1.0,0.1,8.0" option="float" enable="eq(-1,true)" visible="eq(-1,true)"/>
        
        <!-- Optimizaciones para Android -->
        <setting type="sep"/>
        <setting id="android_optimize_enabled" type="bool" label="30004" default="true"/>
        <setting id="buffer_size_limit_android" type="select" label="30005" default="2" values="24 MB|32 MB|48 MB|64 MB|128 MB" enable="eq(-1,true)" visible="eq(-1,true)"/>
        
        <!-- Sincronización de Audio/Video -->
        <setting type="sep"/>
        <setting id="audio_sync_enabled" type="bool" label="30006" default="false"/>
        <setting id="video_delay_correction" type="slider" label="30007" default="0" range="-500,25,500" option="int" enable="eq(-1,true)" visible="eq(-1,true)"/>
        <setting id="audio_delay_correction" type="slider" label="30008" default="0" range="-500,25,500" option="int" enable="eq(-2,true)" visible="eq(-2,true)"/>
        
        <!-- Opciones Avanzadas -->
        <setting type="sep"/>
        <setting id="conservative_buffering" type="bool" label="30009" default="false"/>
        <setting id="aggressive_prefetch" type="bool" label="30010" default="false"/>
    </category>
</settings>
